# API Keys for AI Services (All have FREE tiers!)

# Option 1: Hugging Face (RECOMMENDED - 100% Free)
# Get your free API key at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Option 2: OpenAI (Free credits available)
# Get API key at: https://platform.openai.com/api-keys
# Free trial: $5 credit for new accounts
OPENAI_API_KEY=your_openai_api_key_here

# Option 3: ElevenLabs (Free tier: 10,000 chars/month)
# Get API key at: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Option 4: Google Cloud TTS (Free tier: 1M chars/month)
# Get API key at: https://console.cloud.google.com/
GOOGLE_TTS_API_KEY=your_google_tts_api_key_here

# Note: The app will work with basic features even without API keys!
# It will use fallback methods for narration and analysis.
